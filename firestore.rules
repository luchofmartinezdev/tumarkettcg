rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función helper para saber si el usuario está logueado
    function isSignedIn() {
      return request.auth != null;
    }

    // Perfiles de usuario
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Contactos - El usuario solo puede ver y editar sus propios contactos
    match /contacts/{userId}/records/{recordId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Favoritos - El usuario solo puede ver y editar sus propios favoritos
    match /favorites/{userId}/records/{recordId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Calificaciones - Cualquiera puede leer y crear, pero el autor actualiza
    match /ratings/{sellerId}/records/{ratingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.raterId == request.auth.uid;
    }

    // Publicaciones
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Publicaciones de prueba
    match /posts_test/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    } 
    
    match /config/{document} {
      allow read: if true;
      allow write: if false;
    }
  }
}
